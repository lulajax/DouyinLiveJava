# 配置模板：复制为 .env 后填入自己的值。
#   cp .env.example .env
# 找不到 .env 时程序自动回退到系统环境变量。

# 直播间 web_rid
LIVE_ID=640801847218

# 主播 secUid（仅 StatusThenConnectExample 用：查直播状态 → room_id 直连）
SEC_UID=MS4wLjABAAAA7rOkPwkReCsi5xr42lOi3d8s7hs_4WadleWvQkEwLjw

# 签名服务地址
SIGN_URL=http://localhost:18080

# 登录态 Cookie（整串写一行，用双引号包裹，从浏览器 douyin.com 复制）；留空则匿名连接
DOUYIN_COOKIE=""
